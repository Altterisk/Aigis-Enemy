master_id": 31317, "global_id": 4936, "from_condition": 2}, {"enemy_id": 20, "source": "local", "count": 7, "form_count": 1, "tags": ["鳥"], "hp": 3200, "attack": 300, "base_hp": 3200, "base_attack": 300, "damage_type": "physical", "armor_defense": 350, "magic_defense": 20, "attack_range": 130, "attack_speed": 1, "attack_wait": 3, "attack_interval": 49, "move_speed": 900.0, "gain_cost": 1, "dot_rate": 1.399999976158142, "assassin_resist": 1000, "transform_resist": 1000, "pattern_id": 2123008, "race_id": 12, "special_effect_id": 234, "missile_id": 474, "missile": {"speed": 10.0}, "master_id": 32635, "global_id": 6253, "ranged": true, "spawn_sec": 268}], "popups": ["\n\n\n　　――エッグパーティ当日", "　　　　【天界(弱)】\n・味方攻撃力が最終値から-70。\n・アンデッド、デーモン系を除く\n　味方、敵ユニットの\n　HPが徐々に回復。\n※これらは、風水使いなどがもつ\n　地形効果を軽減する能力では\n　軽減できません。", "エクスがいる間は\n全ての敵のHPが\n徐々に回復します。\n\nまた、エクスの\n周囲にいる敵は\n防御力が上昇します。", "天界では、時間経過によって\n雲の足場が出現する\nことがあります。\n\n出現した雲の足場には、\n遠距離ユニットを\n配置できるようになります。", "グリフィンは一定確率で\n物理攻撃を回避します。"], "active": true}