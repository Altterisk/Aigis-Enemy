ocal", "count": 4, "form_count": 2, "tags": ["精霊(光)"], "hp": 4000, "attack": 350, "base_hp": 4000, "base_attack": 350, "damage_type": "true", "armor_defense": 240, "attack_speed": 1, "attack_wait": 30, "attack_interval": 106, "move_speed": 1000.0, "gain_cost": 1, "dot_rate": 1.2999999523162842, "assassin_resist": 100, "transform_resist": 100, "pattern_id": 2126192, "special_effect_id": 216, "change_to": 49, "missile_id": 509, "missile": {"speed": 15.0, "splash": 67, "slow": [50, 65]}, "master_id": 33116, "global_id": 6733, "to_global_id": 6734, "route_behaviour": {"transforms": [{}]}, "spawn_sec": 310}, {"enemy_id": 49, "source": "local", "count": 1, "form_index": 1, "form_count": 2, "tags": ["精霊(光)"], "hp": 4000, "attack": 350, "base_hp": 4000, "base_attack": 350, "damage_type": "true", "armor_defense": 240, "attack_range": 360, "attack_speed": 1, "attack_wait": 30, "attack_interval": 105, "move_speed": 1000.0, "gain_cost": 1, "dot_rate": 1.2999999523162842, "assassin_resist": 100, "transform_resist": 100, "pattern_id": 2126192, "special_effect_id": 216, "missile_id": 509, "missile": {"speed": 15.0, "splash": 67, "slow": [50, 65]}, "master_id": 33117, "global_id": 6734, "ranged": true}], "popups": ["オーガスタがいる間は、\n全ての敵のHPが\n徐々に回復し、\n一定時間が経過するたびに\n攻撃、防御がアップします。", "レオーネが味方ユニットの\n射程範囲内にいる場合、\n遠距離攻撃を自身に引き付けます。\n\nスキルやアビリティなどで\n攻撃の優先順位が指定された\n敵がいる場合や一部の攻撃は\n引き付けの効果を受けません。", "金光聖菩は分身がいる間、\n攻撃力、防御力がアップします。\nまた、分身の数に応じて効果が\n重複します。", "ソラスは長射程の\n遠距離攻撃を行います。\nまたHPが50％以下になると、\n攻撃対象が3体に増加します。", "エスネアは倒されると\nその場で復活します。\n\n２回まで復活し、\n復活するたびに強くなります。", "ルフレがいる間、\nライトエレメンタルの攻防が\nアップします。\n\nライトエレメンタルは、\nルフレの周囲にいる間は\n遠距離攻撃を行いません。"], "active": true}