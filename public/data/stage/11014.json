": 1.5, "assassin_resist": 1, "transform_resist": 100, "pattern_id": 2116304, "race_id": 9, "special_effect_id": 326, "master_id": 21353, "global_id": 1646, "spawn_sec": 304}, {"enemy_id": 13, "source": "local", "count": 2, "form_count": 1, "hp": 100000, "attack": 900, "base_hp": 100000, "base_attack": 900, "damage_type": "physical", "armor_defense": 2500, "magic_defense": 15, "attack_range": 200, "attack_speed": 150, "attack_wait": 30, "attack_interval": 161, "move_speed": 400.0, "gain_cost": 3, "dot_rate": 1.600000023841858, "assassin_resist": 1, "transform_resist": 1, "pattern_id": 2105760, "race_id": 9, "change_to": 13, "change_condition": 1, "missile_id": 132, "missile": {"speed": 4.0, "splash": 133}, "master_id": 21351, "global_id": 1644, "ranged": true, "variants": [{"hp": 100000, "attack": 4000, "base_hp": 100000, "base_attack": 4000, "damage_type": "physical", "armor_defense": 2500, "magic_defense": 15, "attack_speed": 150, "attack_wait": 50, "attack_interval": 401, "move_speed": 400.0, "gain_cost": 3, "dot_rate": 1.600000023841858, "assassin_resist": 1, "transform_resist": 1, "pattern_id": 2105744, "race_id": 9, "master_id": 21352, "global_id": 1645}], "spawn_sec": 347}], "popups": ["NPC：怒竜の加護鱗\n生存している間、竜族が\n以下の効果を発揮します。\n・攻撃力150％アップ\n・防御力30％アップ\n・出撃コスト半減\n倒されても★の評価には\n影響しません。", "ゴブリン博士から攻撃を\n受けると「毒」状態になり、\n一定時間継続ダメージを受けます。\n\n毒によるダメージは、女神の加護や\n攻撃の無効化の影響を受けませんが\n状態異常に対するユニット能力で\n軽減や回復、無効化が可能です。", "次元の間隙は、\n味方ユニットの射程範囲内にいる場合\n遠距離攻撃を自身に引き付けます。\nさらに、すべての物理攻撃を回避し、\n高い魔法耐性を持ちます。\n\n\n　　　　　　　　　　　(1/2)", "スキルやアビリティなどで\n攻撃の優先順位が指定された\n敵がいる場合や一部の攻撃は\n引き付けの効果を受けません。\n\nまた、次元の間隙は撃破数に\n含まれません。\n　　　　　　　　　　　(2/2)", "ゴブリン博士ロボから攻撃を\n受けると、一定時間スキルが\n使用できなくなります。\n\nこの効果は、状態異常に対する\nユニットの能力では\n軽減、無効化できません。", "ゴブリンの歩行機械は\n攻撃力1500以下の\nあらゆる攻撃を受け付けません。\n\nまた、倒されると\n自身の周囲にダメージを与えます。", "ゴブリン騎獣楽団がいる間は\n敵のゴブリンの攻撃と防御が\nアップします。"], "active": true}